# ──────────────────────────────────────────────────────────────────────
# Copier ce fichier vers .env.local et remplir avec vos vraies valeurs.
# Ne jamais committer .env.local — il contient des secrets.
# ──────────────────────────────────────────────────────────────────────

# ── Email SMTP (Nodemailer) ──────────────────────────────────────────
# Exemples ci-dessous : Gmail (avec mot de passe d'application), OVH,
# Office 365, ou tout autre fournisseur SMTP.
#
# Gmail            : smtp.gmail.com / 587
# OVH              : ssl0.ovh.net / 587
# Office 365       : smtp.office365.com / 587
# SendGrid         : smtp.sendgrid.net / 587 (user = "apikey")
# Mailgun          : smtp.mailgun.org / 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Adresse qui reçoit les messages du formulaire (peut être différente
# de SMTP_USER). Si non définie, SMTP_USER est utilisé.
CONTACT_TO=contact@votre-domaine.com

# ── Next.js ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── WhatsApp Floating Button ──────────────────────────────────────────
# Format international sans espaces ni '+' (ex: 33442072262 pour +33 4 42 07 22 62)
NEXT_PUBLIC_WHATSAPP_NUMBER=33442072262

# ── OpenAI — Chatbot IA ───────────────────────────────────────────────
# Créer une clé sur https://platform.openai.com/api-keys
# NE JAMAIS préfixer par NEXT_PUBLIC_ (clé privée, côté serveur uniquement)
OPENAI_API_KEY=sk-...
