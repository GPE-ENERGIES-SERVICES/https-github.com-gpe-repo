# ──────────────────────────────────────────────────────────────────────
# Copier ce fichier vers .env.local et remplir avec vos vraies valeurs.
# Ne jamais committer .env.local — il contient des secrets.
# ──────────────────────────────────────────────────────────────────────

# ── Email SMTP (Nodemailer) ──────────────────────────────────────────
# Exemples ci-dessous : Gmail (avec mot de passe d'application), OVH,
# Office 365, ou tout autre fournisseur SMTP.
#
# IONOS (SSL/TLS port 465) — configuration actuelle
# Gmail     : smtp.gmail.com / 587 (STARTTLS)
# OVH       : ssl0.ovh.net   / 587
# Office365 : smtp.office365.com / 587
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
SMTP_USER=contact@gpealgerie.com
SMTP_PASS=votre-mot-de-passe-ionos

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO=contact@gpealgerie.com

# ── Next.js ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── WhatsApp Floating Button ──────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=213549480097

# ── OpenAI — Chatbot IA ───────────────────────────────────────────────
# Créer une clé sur https://platform.openai.com/api-keys
# NE JAMAIS préfixer par NEXT_PUBLIC_ (clé privée, côté serveur uniquement)
OPENAI_API_KEY=sk-...
